{
  "appId": "com.Yahya.Rami",
  "appName": "Rami",
  "webDir": ".",
  "ios": {
    "contentInset": "always"
  },
  "android": {
    "buildOptions": {
      "keystorePath": "~/.android/debug.keystore",
      "keystorePassword": "android",
      "keystoreAlias": "androiddebugkey",
      "keystoreAliasPassword": "android",
      "releaseType": "APK"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchFadeOutDuration": 500
    },
    "StatusBar": {
      "style": "light"
    }
  },
  "server": {
    "backgroundColor": "#F5F5DC",
    "cleartext": true
  }
}
